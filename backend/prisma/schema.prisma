// schema.prisma - SpotLightLover
// Mis à jour avec modèle Contest et corrections

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  CANDIDATE
  ADMIN
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentProvider {
  MESOMB
  MTN
  ORANGE
}

enum CandidateStatus {
  PENDING_PAYMENT
  PENDING_VALIDATION
  ACTIVE
  SUSPENDED
  REJECTED
}

enum ContestStatus {
  DRAFT
  OPEN
  CLOSED
  RESULTS_PUBLISHED
}

// ─── Modèles ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  firstName String?
  lastName  String?
  phone     String?
  role      UserRole @default(USER)

  // ✅ AJOUT — protection brute-force login
  loginAttempts Int       @default(0)
  lockedUntil   DateTime?

  googleId String? @unique
  avatar   String?  

  // 2FA (optionnel)
  twoFactorEnabled Boolean @default(false)
  twoFactorSecret  String?

  // Session
  refreshToken String?
  lastLogin    DateTime?

  // Sécurité
  isActive   Boolean @default(true)
  isVerified Boolean @default(false)


  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  candidate        Candidate?
  votesGiven       Vote[]                        @relation("VoterVotes")
  auditLogs        AuditLog[]
  transactions     Transaction[]
  candidatePayment CandidateRegistrationPayment?

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model Candidate {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Infos candidat
  stageName    String  @unique
  bio          String?
  videoUrl     String?
  thumbnailUrl String?
  videoPublicId String?

  status          CandidateStatus @default(PENDING_PAYMENT)
  rejectionReason String?
  moderatedAt     DateTime?
  moderatedBy     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  votesReceived       Vote[]
  registrationPayment CandidateRegistrationPayment?
  leaderboardEntry    LeaderboardEntry?

  @@index([userId])
  @@index([status])
  @@index([stageName])
}

model CandidateRegistrationPayment {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount            Int           @default(500)
  currency          String        @default("XOF")
  status            PaymentStatus @default(PENDING)
  provider          PaymentProvider

  transactionId     String?       @unique
  providerReference String?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
  @@index([userId])
  @@index([status])
}

model Vote {
  id          String    @id @default(uuid())
  candidateId String
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  voterId     String
  voter       User      @relation("VoterVotes", fields: [voterId], references: [id], onDelete: Cascade)

  amount   Int           @default(100)
  currency String        @default("XOF")
  status   PaymentStatus @default(PENDING)
  provider PaymentProvider

  transactionId String?      
  transaction   Transaction? @relation(fields: [transactionId], references: [id])

  ipAddress    String?
  userAgent    String?
  isSuspicious Boolean @default(false)
  isVerified   Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([candidateId])
  @@index([voterId])
  @@index([status])
  @@index([createdAt])
  @@index([transactionId])
}

model Transaction {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     String        // VOTE | REGISTRATION
  amount   Int
  currency String        @default("XOF")
  status   PaymentStatus
  provider PaymentProvider

  providerReference String? @unique
  providerResponse  Json?
  webhookReceived   Boolean @default(false)
  webhookData       Json?

  idempotencyKey String? @unique

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  votes Vote[]

  @@index([userId])
  @@index([status])
  @@index([providerReference])
  @@index([idempotencyKey])
  @@index([createdAt])
}

model LeaderboardEntry {
  id          String    @id @default(uuid())
  candidateId String    @unique
  candidate   Candidate @relation(fields: [candidateId], references: [id], onDelete: Cascade)

  totalVotes  Int      @default(0)
  totalAmount Int      @default(0)
  rank        Int?

  lastUpdated DateTime @default(now())
  createdAt   DateTime @default(now())

  @@index([rank])
  @@index([totalVotes])
}

// ─── Concours ─────────────────────────────────────────────────────────────────

model Contest {
  id     String        @id @default(uuid())
  title  String
  status ContestStatus @default(DRAFT)

  startDate DateTime?
  endDate   DateTime?

  prizeAmount    Int?    // Montant du prix en FCFA
  prizeDescription String?

  // Résultats publiés
  resultsPublishedAt DateTime?
  winnerCandidateId  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ─── Système & Admin ──────────────────────────────────────────────────────────

model SystemSetting {
  id    String @id @default(uuid())
  key   String @unique
  value String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([key])
}

model AuditLog {
  id     String @id @default(uuid())
  userId String?
  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)

  action   String
  resource String
  details  Json?

  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model DailyStats {
  id   String   @id @default(uuid())
  date DateTime @unique @db.Date

  newUsers      Int @default(0)
  newCandidates Int @default(0)
  totalVotes    Int @default(0)
  totalRevenue  Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
}

model WebhookLog {
  id       String @id @default(uuid())
  provider String
  event    String
  payload  Json
  signature String?

  isValid         Boolean @default(false)
  isProcessed     Boolean @default(false)
  processingError String?

  createdAt DateTime @default(now())

  @@index([provider])
  @@index([isProcessed])
  @@index([createdAt])
}

model IpBlacklist {
  id          String    @id @default(uuid())
  ipAddress   String    @unique
  reason      String
  isPermanent Boolean   @default(false)
  expiresAt   DateTime?

  createdAt DateTime @default(now())

  @@index([ipAddress])
  @@index([expiresAt])
}